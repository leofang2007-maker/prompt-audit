# Copy to .env on host1 (gitignored). Consumed by docker-compose(.prod).yml.

# ACR image coordinates (prod pull)
ACR_REGISTRY=cxm-develop-registry-vpc.ap-southeast-1.cr.aliyuncs.com
ACR_NAMESPACE=com.gigrt.cxmdev
TAG=0.0.1

# Host port the server container publishes (bound to 127.0.0.1 in prod). The shared unified-ingress
# nginx forwards audit.theprismatlas.com → 127.0.0.1:${APP_PORT}. See ops/nginx-prompt-audit.site.
APP_PORT=8091

# --- Shared MySQL (dedicated database `promptaudit`) ---
# Reuses host1's mysql.bedrock.internal. Create the DB + a scoped account once:
#   CREATE DATABASE IF NOT EXISTS promptaudit CHARACTER SET utf8mb4;
#   CREATE USER 'promptaudit'@'%' IDENTIFIED BY '<pick-a-strong-password>';
#   GRANT ALL PRIVILEGES ON promptaudit.* TO 'promptaudit'@'%';
# (Or reuse the existing app account utcxmrdssvc1 — see environment/env-credentials.md.)
DB_HOST=mysql.bedrock.internal
DB_PORT=3306
DB_NAME=promptaudit
DB_USER=promptaudit
DB_PASSWORD=

# --- Platform superadmin (bootstrap) — creates orgs, tokens, and org admins in-app ---
ADMIN_EMAIL=admin@promptaudit.local
ADMIN_PASSWORD=            # set a strong password
JWT_SECRET=               # long random string; signs admin session tokens

# --- Global bootstrap ingest token (write side) ---
# Multi-tenant: each org gets its OWN token from the Organizations page. This global token is a
# bootstrap fallback (its data is tenantless — visible only to the platform superadmin). Empty ⇒
# only per-org tokens work.
INGEST_TOKEN=             # long random string (bootstrap); optional once orgs have their own tokens
